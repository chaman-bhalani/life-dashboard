rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    // Returns true only if the request comes from a signed-in user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true only if the signed-in user's uid matches the given userId.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── Users Collection ─────────────────────────────────────────────────────
    // Each document stores profile info keyed by the user's uid.
    match /users/{userId} {
      // Only the owner can read their own profile.
      allow read: if isOwner(userId);

      // Creation: uid must match the doc key; email must be a short string.
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() < 100;

      // Update: owner only; email cannot be changed via client (immutable after creation).
      allow update: if isOwner(userId)
        && request.resource.data.email == resource.data.email;

      // Deletion of the profile document is not permitted from the client.
      allow delete: if false;
    }

    // ─── Tasks Collection ─────────────────────────────────────────────────────
    match /tasks/{taskId} {
      // Only the owner can read or delete their task.
      allow read, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Create: userId must match the caller; validate every field.
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && request.resource.data.priority in ['low', 'medium', 'high']
        && request.resource.data.category in ['Work', 'Personal', 'Health', 'Learning', 'Finance']
        && request.resource.data.status in ['todo', 'in-progress', 'completed'];

      // Update: owner only; userId cannot be changed (no ownership transfer).
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && request.resource.data.priority in ['low', 'medium', 'high']
        && request.resource.data.category in ['Work', 'Personal', 'Health', 'Learning', 'Finance']
        && request.resource.data.status in ['todo', 'in-progress', 'completed'];
    }

    // ─── Habits Collection ────────────────────────────────────────────────────
    match /habits/{habitId} {
      allow read, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.icon is string
        && request.resource.data.icon.size() <= 50;

      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.icon is string
        && request.resource.data.icon.size() <= 50;
    }

    // ─── Moods Collection ─────────────────────────────────────────────────────
    match /moods/{moodId} {
      allow read, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      allow create, update: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.level >= 1
        && request.resource.data.level <= 5;
    }

    // ─── Scratchpads Collection ───────────────────────────────────────────────
    // One document per user, keyed by uid.
    match /scratchpads/{userId} {
      allow read: if isOwner(userId);

      allow create, update: if isOwner(userId)
        && request.resource.data.content is string
        // Hard limit: 50 000 chars prevents storage exhaustion / DoS.
        && request.resource.data.content.size() <= 50000;

      // Allow the user to delete their own scratchpad document.
      allow delete: if isOwner(userId);
    }

    // ─── Default deny ────────────────────────────────────────────────────────
    // Any collection not explicitly listed above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
